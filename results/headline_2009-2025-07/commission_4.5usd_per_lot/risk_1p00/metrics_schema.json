    "martin_ratio": 3,
    "rolling_metrics": 6,
    "kelly": 6,
    "monte_carlo": 6
  },
  "methodology": {
    "monthly_returns_source": "End-of-month NAV (EoM). Missing month-end values are forward-filled to EoM; months with no trades remain with ret_m = 0.",
    "rebasing": {
      "compounding": "Anchor NAV=100000 at t0-ε (just before first observation).",
      "fixed": "Anchor NAV=100000 at YYYY-01-01 00:00 UTC−ε for each calendar year."
    },
    "variance": "All standard deviations are sample (ddof=1).",
    "returns": "Arithmetic (not log).",
    "sharpe_rf": "Sharpe uses rf=0 unless an rf series is supplied (then use effective monthly rf: (1+rf_ann)^(1/12)-1).",
    "drawdown_curve": "MaxDD/Underwater computed on the monthly EoM equity curve: eq_t = Π(1+r_m).",
    "sortino_downside": "Downside σ only over negative months r_m < 0, target=0.",
    "kelly_defaults": "Winsorize R at 1%/99%; search f in [0, f_cap], f_cap = min(0.10, 0.95/|min(R_w)|).",
    "mc_bootstrap_defaults": "Circular block bootstrap on monthly returns; B=5000, block_len_months=3, fixed random seed for reproducibility."
  },
  "definitions": {
    "ret_m": "Monthly return from EoM NAV; decimal units; months with no trades = 0.",
    "cagr": "(Π(1+ret_m))^(12/N) - 1, where N is the number of months.",
    "vol_ann": "stdev(ret_m, ddof=1) * sqrt(12).",
    "sharpe_ann": "(mean(r_m - rf_m) / stdev(r_m - rf_m, ddof=1)) * sqrt(12); rf=0 by default.",
    "sortino_ann": "(mean(r_m) / stdev(r_m[r_m<0], ddof=1)) * sqrt(12); target=0; downside σ on negative months only.",
    "maxdd": "Minimum drawdown on monthly equity: dd_t = eq/cummax(eq) - 1; report the minimum (negative).",
    "mar_full": "cagr / abs(maxdd) computed over the full period on the monthly curve.",
    "longest_underwater_months": "Longest consecutive run of months with dd_t < 0; recovery month (dd=0) not included.",
    "time_underwater_pct": "Share of months with dd_t < 0 over the full sample (decimal).",
    "best_month": "max(ret_m); decimal.",
    "worst_month": "min(ret_m); decimal.",
    "pos_months_pct": "Share of months with ret_m > 0; decimal.",
    "ret_year": "Within-year return from monthly series: Π(1+ret_m_year) - 1.",
    "maxdd_year": "Yearly MaxDD computed on the within-year monthly curve.",
    "ulcer_index": "Ulcer Index on monthly equity: sqrt( mean( max(0, -dd_t)^2 ) ).",
    "martin_ratio": "Annualized mean divided by Ulcer Index: (mean(r_m)*12) / UlcerIndex.",
    "skewness": "Sample skewness of monthly returns.",
    "kurtosis_excess": "Excess kurtosis (Fisher) of monthly returns (kurtosis - 3).",
    "R": "R = pnl_pct if pnl_pct is in fractions; or R = pnl_%/100 if pnl_pct is in percent units (risk_per_trade_pct = 1%).",
    "hit_rate": "Share of trades with R > 0 (zeros are not wins).",
    "profit_factor": "sum(R>0) / |sum(R<=0)| computed on sums (scale‑invariant).",
    "avg_win_r": "mean(R | R>0).",
    "avg_loss_r": "mean(R | R<=0).",
    "payoff_ratio": "avg_win_r / |avg_loss_r|.",
    "expectancy_r_mean": "mean(R).",
    "expectancy_r_median": "median(R).",
    "std_r": "stdev(R, ddof=1).",
    "min_r": "min(R).",
    "max_r": "max(R).",
    "roll_12m_return": "Rolling 12-month return: Π(1+r_m_window) - 1.",
    "roll_12m_sharpe": "Sharpe within each 12-month window: (mean/σ)*sqrt(12), rf=0, ddof=1.",
    "ret_36m_ann": "Annualized return over rolling 36-month window: (Π(1+r_m_window))^(12/36) - 1.",
    "maxdd_36m": "Max drawdown on the monthly equity curve restricted to the 36-month window.",
    "calmar_36m": "ret_36m_ann / |maxdd_36m| (windowed Calmar).",
    "drawdown_quantile": "Left-tail quantiles of dd_t distribution (negative values, e.g., p95/p99).",
    "winsor_lo": "Lower winsorization percentile for R (e.g., 0.01).",
    "winsor_hi": "Upper winsorization percentile for R (e.g., 0.99).",
    "f_opt": "Kelly fraction maximizing E[log(1 + f*R_w)] under winsorized R.",
    "f_half": "f_opt / 2.",
    "f_quarter": "f_opt / 4.",
    "obj_at_f_opt": "Objective value E[log(1 + f_opt*R_w)].",
    "bootstrap_B": "Number of bootstrap replications.",
    "block_len_months": "Block length for circular block bootstrap (months).",
    "cagr_p05": "5th percentile of bootstrapped CAGR distribution.",
    "cagr_p50": "50th percentile (median) of bootstrapped CAGR distribution.",
    "cagr_p95": "95th percentile of bootstrapped CAGR distribution.",
