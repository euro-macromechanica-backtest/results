    "maxdd_p95": "95th percentile of bootstrapped MaxDD distribution (monthly curve).",
    "p_cagr_lt_0": "Probability that CAGR < 0 in bootstrap.",
    "p_maxdd_lt_-0.30": "Probability that MaxDD is shallower than −30% (i.e., dd > −0.30)."
  },
