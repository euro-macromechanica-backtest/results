{
  "about": "Documentation-only JSON for the 7 USD/lot, 1% risk track. Contains no factual values — only field definitions, units, and conventions.",
  "version": "metrics-schema-1.0",
  "generated_at_utc": "2025-09-01T09:20:41Z",
  "units": {
    "returns": "decimal (0.012 = +1.2%)",
    "risk_per_trade_pct": "decimal share of capital (e.g., 0.01 for 1%)",
    "strict_R_classification": {
      "eps": 1e-12,
      "win": "R > +eps",
      "loss": "R < -eps",
      "note": "Zero-R trades are excluded from the win/loss groups and from the PF denominator; for expectancy/std/min/max they are included as-is"
    },
    "timezone": "UTC+0",
    "currency": "USD"
  },
  "rounding_policy": {
    "cagr_vol_maxdd_best_worst": 6,
    "sharpe_sortino": 4,
    "profit_factor_payoff_ratio": 3,
    "hit_rate_pos_months": 6,
    "r_block": 6
  },
  "methodology": {
    "monthly_returns_source": "End-of-month NAV; missing month-end values are ffilled to the month-end; months with no trades remain with ret_m=0.",
    "rebasing": {
      "compounding": "Anchor NAV=100000 at t0-ε (just before first observation).",
      "fixed": "Anchor NAV=100000 at YYYY-01-01 00:00 UTC-ε for each calendar year."
    },
    "variance": "All standard deviations are sample (ddof=1).",
    "sharpe_rf": "Sharpe computed with rf=0 unless an rf series is supplied (then use effective monthly rf: (1+rf_ann)^(1/12)-1).",
    "drawdown_curve": "MaxDD, underwater metrics computed on the monthly EoM equity curve: eq_t = Π(1+r_m)."
  },
  "definitions": {
    "ret_m": "Monthly return from EoM NAV; decimal units; months with no trades = 0.",
    "cagr": "(Π(1+ret_m))^(12/N) - 1, where N is the number of months.",
    "vol_ann": "stdev(ret_m, ddof=1) * sqrt(12).",
    "sharpe_ann": "(mean(r_m - rf_m) / stdev(r_m - rf_m, ddof=1)) * sqrt(12); rf=0 by default.",
    "sortino_ann": "(mean(r_m) / stdev(r_m[r_m<0], ddof=1)) * sqrt(12); target=0; downside σ only on negative months.",
    "maxdd": "Minimum drawdown on monthly equity: dd_t = eq/cummax(eq) - 1; report the minimum (negative).",
    "mar_full": "cagr / abs(maxdd) computed over the full period on the monthly curve.",
    "longest_underwater_months": "Longest consecutive run of months with dd_t < 0; recovery month (dd=0) not included.",
    "best_month": "max(ret_m); decimal.",
    "worst_month": "min(ret_m); decimal.",
    "pos_months_pct": "Share of months with ret_m > 0; decimal.",
    "ret_year": "Within-year return from monthly series: Π(1+ret_m_year) - 1.",
    "maxdd_year": "Yearly MaxDD on the within-year monthly curve.",
    "R": "For risk 1% track: R = pnl_pct (if pnl_pct is in fractions) or pnl_%/100 (if in percent units).",
    "hit_rate": "Share of trades with R > 0 (zeros neither wins nor losses).",
    "profit_factor": "sum(R>0) / |sum(R<=0)| computed on sums (scale-invariant).",
    "avg_win_r": "mean(R | R>0).",
    "avg_loss_r": "mean(R | R<=0).",
    "payoff_ratio": "avg_win_r / |avg_loss_r|.",
    "expectancy_r_mean": "mean(R).",
    "expectancy_r_median": "median(R).",
    "std_r": "stdev(R, ddof=1).",
    "min_r": "min(R).",
